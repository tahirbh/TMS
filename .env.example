# Supabase Configuration
# Get these values from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (only for server-side operations, keep secure!)
# Used for seed scripts and admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Map and API Keys
# VITE_OSRM_API_URL=https://router.project-osrm.org
# VITE_NOMINATIM_API_URL=https://nominatim.openstreetmap.org
# VITE_WEATHER_API_URL=https://api.open-meteo.com
